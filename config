# ===== Target =====
CONFIG_TARGET_bcm27xx=y
CONFIG_TARGET_bcm27xx_bcm2711=y
CONFIG_TARGET_bcm27xx_bcm2711_DEVICE_rpi-4=y

# ===== 文件系统：ext4，禁用 squashfs =====
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=n

# ===== 分区大小：适合 16G SD 卡 =====
# boot 分区约 64MB，root 设 15360MB
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=15360

# ===== LuCI 界面 =====
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# ===== OpenClash =====
CONFIG_PACKAGE_luci-app-openclash=y
# Meta/Mihomo 内核由 diy.sh 在编译后下载放置，OpenClash 首次启动会自动识别

# ===== AdGuard Home =====
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_adguardhome=y

# ===== 基础网络工具 =====
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_iptables=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_iptables-mod-conntrack-extra=y
CONFIG_PACKAGE_iptables-mod-iprange=y
CONFIG_PACKAGE_kmod-tun=y

# DNS（dnsmasq-full 替换默认 dnsmasq，OpenClash 需要）
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dnssec=y

# ===== OpenClash 依赖 =====
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_jsonfilter=y
CONFIG_PACKAGE_ruby=n
CONFIG_PACKAGE_ruby-yaml=n

# ===== 实用工具 =====
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_resize2fs=y
CONFIG_PACKAGE_e2fsprogs=y

# ===== SSH =====
CONFIG_PACKAGE_openssh-sftp-server=y

# ===== 去掉不需要的 =====
CONFIG_PACKAGE_ppp=n
CONFIG_PACKAGE_luci-proto-ppp=n
CONFIG_PACKAGE_kmod-ppp=n

# ===== Argon 主题 =====
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
